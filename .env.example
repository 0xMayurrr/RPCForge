PORT=3000
ADMIN_SECRET=your_admin_secret_here
CACHE_TTL_SECONDS=10
MAX_LOGS=1000

# Ethereum Mainnet
ETH_NODE_1=https://mainnet.infura.io/v3/<YOUR_INFURA_KEY>
ETH_NODE_2=https://eth-mainnet.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>

# Ethereum Sepolia Testnet
SEPOLIA_NODE_1=https://eth-sepolia.g.alchemy.com/v2/<YOUR_ALCHEMY_KEY>

# Polygon Mainnet
POLYGON_NODE_1=https://polygon-rpc.com
POLYGON_NODE_2=https://rpc-mainnet.matic.quiknode.pro

# BSC Mainnet
BSC_NODE_1=https://bsc-dataseed.binance.org
BSC_NODE_2=https://bsc-dataseed1.defibit.io

# Arbitrum Mainnet
ARBITRUM_NODE_1=https://arb1.arbitrum.io/rpc
ARBITRUM_NODE_2=https://arbitrum-one.publicnode.com

# Format: key:tier,key:tier  (tier = free | pro)
API_KEYS=mykey123:free,prokey456:pro
